<div class="newsletter-section" style="background-color: {{ section.settings.bg_color }}; padding: 60px 20px; text-align: center;">
  <h2 style="color: {{ section.settings.text_color }}; margin-bottom: 16px;">
    {{ section.settings.heading }}
  </h2>
  <p style="color: {{ section.settings.text_color }}; margin-bottom: 32px; opacity: 0.8;">
    {{ section.settings.subtext }}
  </p>

  {% form 'customer' %}
    <div style="display: flex; justify-content: center; gap: 12px; flex-wrap: wrap;">
      <input
        type="email"
        name="contact[email]"
        placeholder="{{ section.settings.placeholder }}"
        style="padding: 12px 20px; border: 1px solid #ddd; border-radius: 4px; font-size: 16px; width: 300px;"
        required
      >
      <button
        type="submit"
        style="padding: 12px 28px; background-color: {{ section.settings.button_color }}; color: {{ section.settings.button_text_color }}; border: none; border-radius: 4px; font-size: 16px; cursor: pointer; font-weight: bold;"
      >
        {{ section.settings.button_text }}
      </button>
    </div>
  {% endform %}
</div>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Bleib auf dem Laufenden!"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Untertext",
      "default": "Melde dich an und erhalte exklusive Angebote."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Platzhaltertext",
      "default": "Deine E-Mail Adresse"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Anmelden"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Hintergrundfarbe",
      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Textfarbe",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Farbe",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Textfarbe",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}